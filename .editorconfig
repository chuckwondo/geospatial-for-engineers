# EditorConfig (https://editorconfig.org): baseline file conventions, applied by
# most editors automatically. Mirrors the pre-commit hygiene hooks.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown / Quarto: two trailing spaces are a hard line break, so don't trim.
[*.{md,qmd}]
trim_trailing_whitespace = false

# Python (future executable guides) uses 4-space indentation.
[*.py]
indent_size = 4
